{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Glamin Geometry Authoring Spec",
  "type": "object",
  "required": ["spec_version", "spec_id", "created_at", "owner", "embedder", "spaces", "mints"],
  "properties": {
    "spec_version": { "type": "string" },
    "spec_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "owner": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" },
    "embedder": {
      "type": "object",
      "required": [
        "id",
        "version",
        "input_schema",
        "preprocess_chain",
        "model_hash",
        "config_hash",
        "hardware_class",
        "min_ram_mb",
        "min_vram_mb"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "input_schema": { "type": "string", "minLength": 1 },
        "preprocess_chain": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "model_hash": { "type": "string", "minLength": 1 },
        "config_hash": { "type": "string", "minLength": 1 },
        "hardware_class": {
          "type": "string",
          "enum": ["cpu", "gpu", "npu", "hybrid", "any"]
        },
        "min_ram_mb": { "type": "integer", "minimum": 0 },
        "min_vram_mb": { "type": "integer", "minimum": 0 },
        "signature": { "type": "string" }
      },
      "additionalProperties": false
    },
    "spaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["space_id", "dim", "metric", "normalization"],
        "properties": {
          "space_id": { "type": "string", "minLength": 1 },
          "dim": { "type": "integer", "minimum": 1 },
          "metric": { "type": "string", "minLength": 1 },
          "normalization": { "type": "string", "minLength": 1 },
          "transform_chain": {
            "type": "array",
            "items": { "type": "string" }
          },
          "invariants": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": { "type": "string", "minLength": 1 },
                "equals": {},
                "allowed": { "type": "array" },
                "min": { "type": "number" },
                "max": { "type": "number" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "mints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["mint_id", "space_id", "text"],
        "properties": {
          "mint_id": { "type": "string", "minLength": 1 },
          "space_id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "metadata": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "corridors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["corridor_id", "space_id", "between", "width"],
        "properties": {
          "corridor_id": { "type": "string", "minLength": 1 },
          "space_id": { "type": "string", "minLength": 1 },
          "between": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "maxItems": 2
          },
          "width": { "type": "number", "minimum": 0 },
          "risk_profile": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "traces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["trace_id", "space_id", "steps"],
        "properties": {
          "trace_id": { "type": "string", "minLength": 1 },
          "space_id": { "type": "string", "minLength": 1 },
          "steps": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
